{
  "expo": {
    "name": "Geo Berlin",
    "slug": "geo-berlin",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/GeoChecker_Aruco_Round_01.png",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.timoboese.geoberlin"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#262523"
      },
      "package": "com.timoboese.geoberlin",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Geo Berlin — Berlin Street Edition",
      "shortName": "Geo Berlin",
      "description": "Finde den Berliner Ort! Ein Geografie-Party-Spiel für 2-8 Spieler.",
      "backgroundColor": "#262523",
      "themeColor": "#e94560",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-camera",
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo-google-fonts/space-grotesk/400Regular/SpaceGrotesk_400Regular.ttf",
            "./node_modules/@expo-google-fonts/space-grotesk/500Medium/SpaceGrotesk_500Medium.ttf",
            "./node_modules/@expo-google-fonts/space-grotesk/600SemiBold/SpaceGrotesk_600SemiBold.ttf",
            "./node_modules/@expo-google-fonts/space-grotesk/700Bold/SpaceGrotesk_700Bold.ttf"
          ]
        }
      ],
      "expo-speech-recognition",
      "expo-video",
      "expo-audio",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "b47d3e21-7bed-4c8b-bd12-e805eb1380f8"
      }
    },
    "owner": "tboese"
  }
}
