{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": false,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "jsx": "react-native",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "src/screens/GameScreen.tsx",
    "src/screens/ResultScreen.tsx",
    "src/screens/SetupScreen.tsx",
    "src/screens/TutorialScreen.tsx",
    "src/components/StreetViewImage.tsx",
    "src/components/MapAnswer.tsx"
  ]
}
